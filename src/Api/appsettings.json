{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Properties": {
      "Application": "ProductsApi"
    }
  },
  "Auth": {
    "Authority": "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_CHANGE_ME",
    "Audience": "CHANGE_ME_CLIENT_ID"
  },
  "DynamoDb": {
    "TableName": "products"
  },
  "AWS": {
    "Region": "us-east-1"
  },
  "UseInMemoryDatabase": false,
  "AllowedHosts": "*"
}
